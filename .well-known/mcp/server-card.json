      }
    },
    {
      "name": "perseus_mason",
      "description": "Mason code architecture concept map (feature\u2192file)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @mason directive"
          }
        },
        "required": []
      }
    },
    {
      "name": "perseus_memory",
      "description": "Mn\u0113m\u0113 v2 \u2014 unified memory search + narrative + federation",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "description": "Query mode: search, narrative, or federation"
          },
          "query": {
            "type": "string",
            "description": "Search query string for BM25 / hybrid recall"
          },
          "scope": {
            "type": "string",
            "description": "Memory scope filter: working, core, or all"
          },
          "k": {
            "type": "string",
            "description": "Number of results to return (default: 5)"
          },
          "type": {
            "type": "string",
            "description": "Memory type filter"
          },
          "render": {
            "type": "string",
            "description": "If 'true', render matched memories as markdown"
          },
          "focus": {
            "type": "string",
            "description": "Time focus: recent, today, week, or all"
          },
          "federation": {
            "type": "string",
            "description": "Enable cross-workspace federation"
          },
          "include_federation": {
            "type": "string",
            "description": "Include federation results in output"
          },
          "alias": {
            "type": "string",
            "description": "Workspace alias for federation targeting"
          },
          "workspace": {
            "type": "string",
            "description": "Target workspace path for scoped queries"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "mode": {
            "type": "string",
            "description": "Query mode used"
          },
          "count": {
            "type": "integer",
            "description": "Number of results returned"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_mneme",
      "description": "Recall persistent memories via Mn\u0113m\u0113 BM25",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "BM25 FTS5 search query for persistent memory recall"
          },
          "scope": {
            "type": "string",
            "description": "Memory scope filter"
          },
          "k": {
            "type": "string",
            "description": "Number of results to return (default: 5)"
          },
          "type": {
            "type": "string",
            "description": "Memory type filter"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "query": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "perseus_perseus",
      "description": "Fetch rendered context from a remote Perseus instance",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @perseus directive"
          }
        },
        "required": []
      }
    },
    {
      "name": "perseus_prompt",
      "description": "System prompt block",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @prompt directive"
          }
        },
        "required": []
      }
    },
    {
      "name": "perseus_read",
      "description": "Embed file contents",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "File path to read (relative to workspace root)"
          },
          "key": {
            "type": "string",
            "description": "If reading a config file, extract this key only"
          },
          "fallback": {
            "type": "string",
            "description": "Value to use when the file or key is not found"
          },
          "schema": {
            "type": "string",
            "description": "JSON Schema to validate file contents against"
          }
        },
        "required": [
          "path"
        ]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_services",
      "description": "Health-check listed services",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @services directive"
