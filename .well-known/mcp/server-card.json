          "limit": {
            "type": "string",
            "description": "Maximum number of messages to return"
          }
        },
        "required": []
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_include",
      "description": "Include and render another file",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @include directive"
          }
        },
        "required": []
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
