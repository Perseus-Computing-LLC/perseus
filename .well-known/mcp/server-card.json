      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "mode": {
            "type": "string",
            "description": "Query mode used"
          },
          "count": {
            "type": "integer",
            "description": "Number of results returned"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
