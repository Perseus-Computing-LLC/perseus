          "schema": {
            "type": "string",
            "description": "JSON Schema to validate the env var value against"
          }
        },
        "required": []
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_health",
      "description": "Context maintenance report",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @health directive"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Overall health: ok, warning, or critical"
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "stale_skills": {
            "type": "integer",
            "description": "Count of skills past freshness threshold"
          },
          "duplicate_tasks": {
            "type": "integer",
            "description": "Count of duplicate task entries"
          },
          "oversized_context": {
            "type": "boolean",
            "description": "Whether rendered context exceeds size limits"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_inbox",
