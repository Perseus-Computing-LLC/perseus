            "type": "string",
            "description": "strftime format string (default: %Y-%m-%d %H:%M:%S)"
          }
        },
        "required": []
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_drift",
      "description": "Oracle drift report",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @drift directive"
          }
        },
        "required": []
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_env",
      "description": "Embed environment variable",
      "inputSchema": {
        "type": "object",
        "properties": {
          "required": {
            "type": "string",
            "description": "If 'true', render fails when the variable is unset"
          },
          "fallback": {
            "type": "string",
