{
  "serverInfo": {
    "name": "perseus",
    "version": "1.0.6"
  },
  "authentication": {
    "required": false,
    "schemes": []
  },
  "tools": [
    {
      "name": "perseus_agora",
      "description": "Task board from tasks/*.md",
      "inputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Filter tasks by status: open, in_progress, completed, cancelled"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Task identifier"
                },
                "title": {
                  "type": "string",
                  "description": "Task title"
                },
                "status": {
                  "type": "string",
                  "description": "Task status"
                },
                "scope": {
                  "type": "string",
                  "description": "Effort estimate"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_auto-skill",
      "description": "Instruct agent to load a skill before work begins",
      "inputSchema": {
        "type": "object",
        "properties": {
          "skill": {
            "type": "string",
            "description": "Name of the skill the agent should load before beginning work"
          }
        },
        "required": []
      }
    },
    {
      "name": "perseus_date",
