{
  "serverInfo": {
    "name": "perseus",
    "version": "1.0.7"
  },
  "authentication": {
    "required": false,
    "schemes": []
  },
  "tools": [
    {
      "name": "perseus_agora",
      "description": "List tasks from the project task board (tasks/*.md files). Use to see what is open, in progress, or completed. Filter by status. Read-only; returns task array with id, title, status, scope.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Filter tasks by status: open, in_progress, completed, cancelled"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Task identifier"
                },
                "title": {
                  "type": "string",
                  "description": "Task title"
                },
                "status": {
                  "type": "string",
                  "description": "Task status"
                },
                "scope": {
                  "type": "string",
                  "description": "Effort estimate"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_auto_skill",
      "description": "Instruct the agent to load a specific skill before starting work. Use at the top of context documents to enforce critical hygiene skills (e.g., memory-hygiene, agent-safety). Renders as a mandatory instruction block. Read-only.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "skill": {
            "type": "string",
            "description": "Name of the skill the agent should load before beginning work"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rendered": {
            "type": "string",
            "description": "Resolved directive output as markdown"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_date",
      "description": "Current date/time",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "strftime format string (default: %Y-%m-%d %H:%M:%S)"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "datetime": {
            "type": "string",
            "description": "Current date/time string"
          },
          "iso8601": {
            "type": "string",
            "description": "ISO-8601 formatted timestamp"
          },
          "unix": {
            "type": "integer",
            "description": "Unix epoch seconds"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_drift",
      "description": "Detect drift between predicted and actual tool usage patterns via the Pythia oracle. Use when tool behavior seems off or after config changes. For workspace hygiene checks, prefer perseus_health. Read-only; returns a markdown drift report.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @drift directive"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rendered": {
            "type": "string",
            "description": "Resolved directive output as markdown"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_env",
      "description": "Embed environment variable",
      "inputSchema": {
        "type": "object",
        "properties": {
          "required": {
            "type": "string",
            "description": "If 'true', render fails when the variable is unset"
          },
          "fallback": {
            "type": "string",
            "description": "Value to use when the environment variable is not set"
          },
          "schema": {
            "type": "string",
            "description": "JSON Schema to validate the env var value against"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "variable": {
            "type": "string",
            "description": "Environment variable name"
          },
          "value": {
            "type": "string",
            "description": "Resolved value or fallback"
          },
          "source": {
            "type": "string",
            "description": "Where the value was resolved from"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_health",
      "description": "Audit workspace context health: stale skills, duplicate tasks, oversized output. Use before starting work to catch drift. For deep Daedalus heuristics (cache, directive stats), use perseus_get_health. Read-only; returns status enum and metric counts.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @health directive"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Overall health: ok, warning, or critical"
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "stale_skills": {
            "type": "integer",
            "description": "Count of skills past freshness threshold"
          },
          "duplicate_tasks": {
            "type": "integer",
            "description": "Count of duplicate task entries"
          },
          "oversized_context": {
            "type": "boolean",
            "description": "Whether rendered context exceeds size limits"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_inbox",
      "description": "Read agent-to-agent messages from the workspace inbox. Use to check for coordination messages from other agents. Filter to unread only. Read-only; returns message array with read/unread status.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "unread": {
            "type": "string",
            "description": "If 'true', show only unread messages"
          },
          "limit": {
            "type": "string",
            "description": "Maximum number of messages to return"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Message identifier"
                },
                "content": {
                  "type": "string",
                  "description": "Message body"
                },
                "sender": {
                  "type": "string",
                  "description": "Message sender"
                },
                "timestamp": {
                  "type": "string",
                  "description": "ISO-8601 timestamp"
                },
                "read": {
                  "type": "boolean",
                  "description": "Whether the message has been read"
                }
              }
            }
          },
          "unread_count": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_include",
      "description": "Include and render another Perseus source file, recursively resolving its directives. Use to compose context from multiple files or share common sections across workspaces. Read-only; resolved directives inherit the parent configuration.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "File path to include and render (relative to workspace root)"
          }
        },
        "required": [
          "path"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rendered": {
            "type": "string",
            "description": "Rendered included file content"
          },
          "source": {
            "type": "string",
            "description": "Included file path"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_list",
      "description": "List directory contents or structured data. Use to discover files before reading with perseus_read. Supports sorting by name, modified time, or size. Read-only; for hierarchical view, prefer perseus_tree.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Directory path to list (default: workspace root)"
          },
          "limit": {
            "type": "string",
            "description": "Value for limit parameter"
          },
          "sort": {
            "type": "string",
            "description": "Value for sort parameter"
          }
        },
        "required": [
          "path"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "description": "file or directory"
                },
                "size": {
                  "type": "integer",
                  "description": "Size in bytes"
                },
                "modified": {
                  "type": "string",
                  "description": "Last modified timestamp"
                }
              }
            }
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_mason",
      "description": "Query the Mason code architecture concept map to find which files implement a feature. Use before editing code to understand where changes should go. Read-only; returns concept map and mapped file list.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Feature or filename to look up in the Mason code architecture map"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "concept_map": {
            "type": "string",
            "description": "Mason code architecture concept map"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Mapped source files"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_memory",
      "description": "Search LOCAL project memory (FTS5, zero-network) for past decisions and architecture notes. Use for in-workspace recall. For cross-session persistent facts, use perseus_mimir instead. Read-only; returns results array with mode and count.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "description": "Query mode: search, narrative, or federation"
          },
          "query": {
            "type": "string",
            "description": "Search query string for BM25 / hybrid recall"
          },
          "scope": {
            "type": "string",
            "description": "Memory scope filter: working, core, or all"
          },
          "k": {
            "type": "string",
            "description": "Number of results to return (default: 5)"
          },
          "type": {
            "type": "string",
            "description": "Memory type filter"
          },
          "render": {
            "type": "string",
            "description": "If 'true', render matched memories as markdown"
          },
          "focus": {
            "type": "string",
            "description": "Time focus: recent, today, week, or all"
          },
          "federation": {
            "type": "string",
            "description": "Enable cross-workspace federation"
          },
          "include_federation": {
            "type": "string",
            "description": "Include federation results in output"
          },
          "alias": {
            "type": "string",
            "description": "Workspace alias for federation targeting"
          },
          "workspace": {
            "type": "string",
            "description": "Target workspace path for scoped queries"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "mode": {
            "type": "string",
            "description": "Query mode used"
          },
          "count": {
            "type": "integer",
            "description": "Number of results returned"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_mimir",
      "description": "Query the EXTERNAL Mimir memory server for cross-session, curated facts that survive across workspaces. Use for long-lived knowledge (bug patterns, design decisions). For fast local recall, prefer perseus_memory. Read-only; falls back to local FTS5 if Mimir is unreachable.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "BM25 FTS5 search query for persistent memory recall"
          },
          "scope": {
            "type": "string",
            "description": "Memory scope filter"
          },
          "k": {
            "type": "string",
            "description": "Number of results to return (default: 5)"
          },
          "type": {
            "type": "string",
            "description": "Memory type filter"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "query": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_perseus",
      "description": "Fetch rendered context from a remote Perseus instance by URL. Use to pull live workspace state from another machine or container. Read-only; caches results \u2014 re-fetch when remote state may have changed.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL of the remote Perseus instance to fetch context from"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rendered": {
            "type": "string",
            "description": "Remote Perseus context as markdown"
          },
          "source_url": {
            "type": "string",
            "description": "URL of the remote Perseus instance"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_prompt",
      "description": "Define a system prompt block that instructs the AI assistant about how to use the rendered context. Use to set behavioral rules, memory hygiene gates, or context interpretation guidelines. Read-only; rendered as-is into the output.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @prompt directive"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rendered": {
            "type": "string",
            "description": "System prompt block content"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_read",
      "description": "Read and embed file contents into the rendered context. Use to inject config values, environment files, or any text file. Can extract specific keys from structured files. Read-only; use perseus_list or perseus_tree to browse before reading.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "File path to read (relative to workspace root)"
          },
          "key": {
            "type": "string",
            "description": "If reading a config file, extract this key only"
          },
          "fallback": {
            "type": "string",
            "description": "Value to use when the file or key is not found"
          },
          "schema": {
            "type": "string",
            "description": "JSON Schema to validate file contents against"
          }
        },
        "required": [
          "path"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "File contents"
          },
          "path": {
            "type": "string",
            "description": "File path read"
          },
          "truncated": {
            "type": "boolean",
            "description": "Whether content was truncated"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_services",
      "description": "Health-check all services listed in the workspace context (HTTP endpoints, Docker containers, shell commands). Use to verify the environment is healthy before starting work. May make network calls and execute shell commands per service definition \u2014 side effects depend on configured checks.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "args": {
            "type": "string",
            "description": "Arguments for @services directive"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "services": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "description": "up, down, or unknown"
                },
                "latency_ms": {
                  "type": "number",
                  "description": "Response latency in milliseconds"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "destructiveHint": true
      }
    },
    {
      "name": "perseus_session",
      "description": "List recent session digests with task summaries and outcomes. Use to understand what was done recently across sessions. For the single most recent checkpoint, prefer perseus_waypoint. Read-only; returns session array with count.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "count": {
            "type": "string",
            "description": "Number of recent sessions to include (default: 3)"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "sessions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_skills",
      "description": "List available skills with descriptions and freshness status. Use to discover what capabilities are installed. Filter by category for smaller output. Read-only; stale skills flagged automatically.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "flag_stale": {
            "type": "string",
            "description": "If 'true', mark skills not updated within threshold as stale"
          },
          "category": {
            "type": "string",
            "description": "Filter skills by category (e.g., devops, github)"
          },
          "limit": {
            "type": "string",
            "description": "Maximum number of skills to list"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "category": {
                  "type": "string"
                },
                "stale": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_tool",
      "description": "Run an external tool that has been allowlisted in the Perseus configuration. Use for approved integrations only. Requires the tool name to be present in the allowlist. Destructive \u2014 executes the tool with the user's permissions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the allowlisted external tool to run"
          }
        },
        "required": [
          "name"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "output": {
            "type": "string",
            "description": "External tool stdout"
          },
          "exit_code": {
            "type": "integer",
            "description": "Tool exit code"
          }
        }
      },
      "annotations": {
        "destructiveHint": true
      }
    },
    {
      "name": "perseus_tooltrim",
      "description": "Return filtered toolset metadata and usage statistics. Use to understand what tools are available and how they are being used. For full tool metadata, set full=true. Read-only; stats mode returns aggregated counts.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "stats": {
            "type": "string",
            "description": "If 'true', return tool usage statistics"
          },
          "full": {
            "type": "string",
            "description": "If 'true', return complete tool metadata"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "tools": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "integer",
            "description": "Number of tools listed"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_tree",
      "description": "Display a directory tree with configurable depth. Use to understand project structure at a glance. For flat file listings with metadata, use perseus_list instead. Read-only; depth limits control output size.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Directory path for tree display (default: workspace root)"
          },
          "depth": {
            "type": "string",
            "description": "Value for depth parameter"
          }
        },
        "required": [
          "path"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "tree": {
            "type": "string",
            "description": "Directory tree as formatted text"
          },
          "root": {
            "type": "string",
            "description": "Root directory path"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_validate",
      "description": "Validate a rendered block against a JSON Schema. Use to enforce structure on configuration blocks, task definitions, or any schema-constrained section. Read-only; returns pass/fail with error messages.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "schema": {
            "type": "string",
            "description": "JSON Schema to validate the rendered block against"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean",
            "description": "Whether validation passed"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Validation error messages"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_waypoint",
      "description": "Return the most recent session checkpoint: what was being worked on, status, and next steps. Use at session start to resume where you left off. Stale after TTL (default 24h). Read-only; lightweight \u2014 call freely.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "ttl": {
            "type": "string",
            "description": "Max age in seconds for a valid checkpoint (default: 86400)"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "checkpoint": {
            "type": "string",
            "description": "Latest checkpoint summary text"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 timestamp of checkpoint"
          },
          "stale": {
            "type": "boolean",
            "description": "Whether the checkpoint exceeds TTL"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "perseus_get_context",
      "description": "Return the full rendered Perseus context for the workspace.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "Output format: markdown or json (default: markdown)"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rendered": {
            "type": "string",
            "description": "Full rendered context"
          },
          "format": {
            "type": "string",
            "description": "Output format used"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true
      }
