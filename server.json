{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Perseus-Computing-LLC/perseus",
  "title": "Perseus: MCP server and live context engine",
  "description": "Live context MCP server: resolves git, services, and tests into agent context. Local-first, MIT.",
  "version": "1.0.22",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "perseus-ctx",
      "version": "1.0.22",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "positional",
          "value": "serve"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "websiteUrl": "https://github.com/Perseus-Computing-LLC/perseus",
  "repository": {
    "source": "github",
    "url": "https://github.com/Perseus-Computing-LLC/perseus"
  }
}
