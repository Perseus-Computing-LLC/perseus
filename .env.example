# Perseus — Environment Variables
# Copy to .env and fill in values as needed.
# See SETUP-GUIDE.md for full configuration instructions.

# ── Security Gate (v1.0.6+) ────────────────────────────────────────
# REQUIRED to enable @query, @agent, @services command:,
# workspace-sourced plugins, and workspace-sourced shell hooks.
# Without this, shell-executing directives are silently skipped.
PERSEUS_ALLOW_DANGEROUS=1

# ── Paths ──────────────────────────────────────────────────────────
# Perseus home directory (default: ~/.perseus)
# PERSEUS_HOME=~/.perseus

# Custom template directory for `perseus init`
# PERSEUS_TEMPLATE_DIR=~/.perseus/templates

# Override session and skill directories (also read from Hermes Agent)
# PERSEUS_SESSIONS_DIR=~/.hermes/sessions
# PERSEUS_SKILLS_DIR=~/.hermes/skills
# HERMES_SESSIONS_DIR=~/.hermes/sessions
# HERMES_SKILLS_DIR=~/.hermes/skills

# ── LLM Backends (choose one) ──────────────────────────────────────
# Gemini free tier (recommended) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Groq free tier (very fast inference)
# GROQ_API_KEY=your-key-here

# OpenAI (paid)
# OPENAI_API_KEY=your-key-here

# DeepSeek (paid)
# DEEPSEEK_API_KEY=your-key-here

# Ollama local host override (default: http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434

# ── Development / Debug ────────────────────────────────────────────
# PERSEUS_DEBUG=1       # Enable debug logging
# PERSEUS_BENCH=1       # Enable benchmark mode
